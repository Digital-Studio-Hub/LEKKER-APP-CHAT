{
  "expo": {
    "name": "Lekker Chat",
    "slug": "lekker-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lekkerchat",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lekker.chat",
      "infoPlist": {
        "UIRequiresFullScreen": false
      }
    },
    "android": {
      "package": "com.lekker.chat",
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Lekker Chat uses your location to find nearby Lekkerpreneurs and enhance your networking experience.",
          "locationWhenInUsePermission": "Lekker Chat uses your location to find nearby Lekkerpreneurs."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#F5C518"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Lekker Chat needs access to your photos to share images in conversations.",
          "cameraPermission": "Lekker Chat needs camera access to take photos and share them in conversations."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Lekker Chat needs access to your contacts so you can share them in conversations."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Lekker Chat needs microphone access to record voice notes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
