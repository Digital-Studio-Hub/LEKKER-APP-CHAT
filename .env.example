# Lekker Chat — local environment template
# Copy to .env — DATABASE_URL from Neon console (pooled connection string)

# =============================================================================
# MOBILE APP (required for Expo / iOS)
# =============================================================================

# Host:port only (no protocol). Uses http for localhost/LAN, https otherwise.
EXPO_PUBLIC_DOMAIN=localhost:5000

# Optional full override, e.g. https://your-app.replit.app:5000
# EXPO_PUBLIC_API_URL=

# =============================================================================
# LOCAL SERVER (npm run server:dev)
# =============================================================================

PORT=5000
NODE_ENV=development

# Required — Neon pooled connection string (same account as lekker.network)
# Neon console → Connection details → Pooled connection → copy DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/DATABASE?sslmode=require

# Required — JWT signing (generate: openssl rand -base64 32)
SESSION_SECRET=

# =============================================================================
# LEKKER.NETWORK INTEGRATION
# =============================================================================

LEKKER_API_BASE_URL=https://lekker.network
LEKKER_NETWORK_API_URL=https://lekker.network/api/v1/lekkerpreneurs
LEKKER_NETWORK_API_KEY=

# Connect API (workspace forms/CRM) — from lekker.network → Settings → Connect API
LEKKER_WORKSPACE_ID=
LEKKER_TOKEN=

# =============================================================================
# OPTIONAL (Replit / production features)
# =============================================================================

# AI_INTEGRATIONS_OPENROUTER_BASE_URL=
# AI_INTEGRATIONS_OPENROUTER_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=